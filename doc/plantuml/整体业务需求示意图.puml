@startuml 整体业务需求示意图
title 科研文献智能解析与知识服务系统 — 整体业务需求示意图

left to right direction

package "用户账户系统" as M0 #E8F5E9 {
    usecase (匿名访问) as UC0a
    usecase (注册登录) as UC0b
    usecase (跨设备\n数据同步) as UC0c
}

package "论文上传与管理" as M1 #FFF3E0 {
    usecase (PDF文件上传) as UC1a
    usecase (文献列表\n检索筛选) as UC1b
    usecase (解析状态\n查看与重试) as UC1c
}

package "PDF智能解析" as M2 #E3F2FD {
    usecase (文本抽取\n与章节识别) as UC2a
    usecase (结构化\n信息抽取) as UC2b
    usecase (图表与参考\n文献提取) as UC2c
}

package "知识库构建" as M3 #F3E5F5 {
    usecase (文本分块\n与BGE向量化) as UC3a
    usecase (FAISS语义\n索引构建) as UC3b
    usecase (知识库\n状态管理) as UC3c
}

package "论文智能问答" as M4 #E0F7FA {
    usecase (单轮\n事实问答) as UC4a
    usecase (多轮\n对话追问) as UC4b
    usecase (答案来源\n页码溯源) as UC4c
}

package "研读报告生成" as M5 #FFF9C4 {
    usecase (速读报告) as UC5a
    usecase (方法总结报告) as UC5b
    usecase (实验总结报告) as UC5c
}

package "管理与可视化" as M6 #FCE4EC {
    usecase (标签分类管理) as UC6a
    usecase (阅读进度跟踪) as UC6b
    usecase (问答历史查看) as UC6c
    usecase (知识库状态\n展示) as UC6d
}

' 用户入口
actor "用户" as User

User --> M0
User --> M1

' 模块间数据流
M0 ..> M1 : 身份绑定
M0 ..> M6 : 个人数据
M1 --> M2 : 上传后\n触发解析
M2 --> M3 : 结构化文本\n写入知识库
M3 --> M4 : 语义检索\n支撑问答
M3 --> M5 : 片段检索\n支撑报告
M4 --> M6 : 对话记录\n沉淀
M5 --> M6 : 报告文件\n留存

note right of M2
  技术支撑：
  PyMuPDF + LLM信息抽取
end note

note right of M3
  技术支撑：
  BGE Embedding + FAISS
end note

note right of M4
  技术支撑：
  RAG检索增强生成
end note

@enduml
